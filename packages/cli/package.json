{
  "name": "flowforger",
  "version": "0.1.4",
  "description": "CLI for FlowForger — compile TypeScript DSL to Power Automate / Logic Apps workflows, validate, run locally, and deploy",
  "keywords": [
    "power-automate",
    "logic-apps",
    "workflow",
    "flow",
    "microsoft",
    "dsl",
    "typescript",
    "low-code",
    "automation",
    "flowforger"
  ],
  "license": "Apache-2.0",
  "author": "Damjan Tomic",
  "homepage": "https://flowforger.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomdam/flowforger.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/tomdam/flowforger/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "flowforger": "dist/bundle.cjs"
  },
  "files": [
    "dist/bundle.cjs",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node esbuild.config.mjs",
    "prepublishOnly": "tsc -b && node esbuild.config.mjs && node scripts/copy-skills.mjs",
    "test": "node --eval \"console.log('ok')\""
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.1",
    "@azure/msal-node-extensions": "^5.1.1",
    "ts-morph": "^24.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@flowforger/connectors-dataverse": "^0.1.0",
    "@flowforger/connectors-excelonline": "^0.1.0",
    "@flowforger/connectors-http": "^0.1.0",
    "@flowforger/connectors-office365": "^0.1.0",
    "@flowforger/connectors-office365groups": "^0.1.0",
    "@flowforger/connectors-office365users": "^0.1.0",
    "@flowforger/connectors-onedrive": "^0.1.0",
    "@flowforger/connectors-sharepoint": "^0.1.0",
    "@flowforger/connectors-teams": "^0.1.0",
    "@flowforger/connectors-wordonline": "^0.1.0",
    "@flowforger/dataverse-sdk": "^0.1.0",
    "@flowforger/dsl-language-service": "^0.1.0",
    "@flowforger/dsl-native": "^0.1.0",
    "@flowforger/emitter-logicapps": "^0.1.0",
    "@flowforger/engine": "^0.1.0",
    "@flowforger/ir": "^0.1.0",
    "@flowforger/validator": "^0.1.0"
  }
}
