{
  "name": "flowforger",
  "private": true,
  "version": "0.0.0",
  "description": "Build, run, and emit Microsoft Power Automate and Azure Logic Apps workflows in TypeScript",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomdam/flowforger.git"
  },
  "homepage": "https://github.com/tomdam/flowforger#readme",
