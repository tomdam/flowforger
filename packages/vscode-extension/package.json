{
  "name": "flowforger-vscode",
  "version": "0.1.7",
  "private": true,
  "description": "Power Automate & Logic Apps flows as TypeScript — IntelliSense, local debugging, and compilation to Logic Apps JSON",
  "keywords": [
    "power automate",
    "logic apps",
    "flowforger",
    "typescript",
    "workflow"
  ],
  "license": "Apache-2.0",
  "author": "Damjan Tomic",
  "homepage": "https://flowforger.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomdam/flowforger.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/tomdam/flowforger/issues"
  },
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "displayName": "FlowForger",
  "publisher": "flowforger",
  "icon": "flowforgericon.png",
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:**/*.ff.ts",
    "onDebugResolve:flowforger"
  ],
  "contributes": {
    "languages": [
      {
        "id": "flowforger",
        "aliases": [
          "FlowForger DSL",
          "flowforger"
        ],
        "extensions": [
          ".ff.ts"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flowforger",
        "scopeName": "source.flowforger",
        "path": "./syntaxes/flowforger.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flowforger",
        "path": "./snippets/flowforger.json"
      }
    ],
    "configuration": {
      "title": "FlowForger",
      "properties": {
        "flowforger.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable FlowForger language features"
        },
        "flowforger.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic reporting"
        },
        "flowforger.diagnostics.showUnusedWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show warnings for unused actions and variables"
        },
        "flowforger.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the FlowForger language server"
        }
      }
    },
    "commands": [
      {
        "command": "flowforger.restartServer",
        "title": "FlowForger: Restart Language Server"
      },
      {
        "command": "flowforger.compileToIR",
        "title": "FlowForger: Compile to IR"
      },
      {
        "command": "flowforger.compileToLogicApps",
        "title": "FlowForger: Compile to Logic Apps JSON"
      },
      {
        "command": "flowforger.debugFlow",
        "title": "FlowForger: Debug Flow"
      }
    ],
    "breakpoints": [
      {
        "language": "flowforger"
      }
    ],
    "debuggers": [
      {
        "type": "flowforger",
        "label": "FlowForger Debug",
        "languages": [
          "flowforger"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .ff.ts file to debug",
                "default": "${file}"
              },
              "triggerPayload": {
                "type": [
                  "string",
                  "object"
                ],
                "description": "Trigger payload (JSON object or path to .json file)",
                "default": {}
              },
              "variables": {
                "type": "object",
                "description": "Initial variable values",
                "default": {}
              },
              "parameters": {
                "type": "object",
                "description": "Environment variable / parameter overrides (key-value pairs for parameters() expressions)",
                "default": {}
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop on the first action",
                "default": false
              },
              "spToken": {
                "type": "string",
                "description": "SharePoint access token"
              },
              "dvUrl": {
                "type": "string",
                "description": "Dataverse URL (e.g. https://org.crm.dynamics.com)"
              },
              "dvToken": {
                "type": "string",
                "description": "Dataverse access token"
              },
              "graphToken": {
                "type": "string",
                "description": "Microsoft Graph / Office 365 access token"
              },
              "auth": {
                "type": "boolean",
                "description": "Automatically acquire tokens using MSAL (requires flowforger.config.json with auth section)",
                "default": false
              },
              "config": {
                "type": "string",
                "description": "Path to flowforger.config.json (defaults to workspace root)"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "FlowForger: Debug Current Flow",
            "description": "Debug the current .ff.ts file",
            "body": {
              "type": "flowforger",
              "request": "launch",
              "name": "Debug FlowForger Flow",
              "program": "${file}",
              "stopOnEntry": false
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:ext -- --minify && npm run build:server -- --minify",
    "build:ext": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:server": "esbuild ../lsp-server/src/server.ts --bundle --outfile=server/dist/index.js --format=cjs --platform=node",
    "build": "npm run build:ext -- --sourcemap && npm run build:server -- --sourcemap",
    "watch": "npm run build:ext -- --sourcemap --watch",
    "compile": "tsc",
    "package": "vsce package --no-dependencies",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "install-ext": "npm run package && \"%LOCALAPPDATA%/Programs/Microsoft VS Code/bin/code.cmd\" --install-extension flowforger-vscode-0.1.3.vsix",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "@vscode/debugadapter": "^1.68.0",
    "@azure/msal-node": "^5.1.1",
    "@flowforger/dsl-native": "^0.1.0",
    "@flowforger/emitter-logicapps": "^0.1.0",
    "@flowforger/engine": "^0.1.0",
    "@flowforger/ir": "^0.1.0",
    "@flowforger/connectors-http": "^0.1.0",
    "@flowforger/connectors-sharepoint": "^0.1.0",
    "@flowforger/connectors-dataverse": "^0.1.0",
    "@flowforger/connectors-office365": "^0.1.0",
    "@flowforger/connectors-office365users": "^0.1.0",
    "@flowforger/connectors-wordonline": "^0.1.0",
    "@flowforger/connectors-excelonline": "^0.1.0",
    "@flowforger/connectors-teams": "^0.1.0",
    "@flowforger/connectors-onedrive": "^0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.1",
    "typescript": "^5.3.0"
  }
}
