{
  "name": "@flowforger/ir",
  "version": "0.1.0",
  "description": "FlowForger intermediate representation (IR) — core types for Power Automate / Logic Apps flow definitions",
  "keywords": [
    "power-automate",
    "logic-apps",
    "workflow",
    "flowforger",
    "typescript",
    "automation",
    "intermediate-representation"
  ],
  "license": "Apache-2.0",
  "author": "Damjan Tomic",
  "homepage": "https://flowforger.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomdam/flowforger.git",
    "directory": "packages/ir"
  },
  "bugs": {
    "url": "https://github.com/tomdam/flowforger/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "schema": "ts-json-schema-generator --path src/index.ts --type FlowIR --tsconfig tsconfig.json --out schema/flowforger-ir.schema.json --no-type-check --additional-properties",
    "test": "npx tsx --test test/diff.test.ts"
  }
}
